{
  "name": "mcp-generator",
  "version": "1.0.0",
  "description": "CLI tool to generate Model Context Protocol (MCP) server boilerplate with interactive wizard",
  "main": "dist/index.js",
  "bin": {
    "mcp-generator": "./dist/index.js",
    "mcp-gen": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "generator",
    "boilerplate",
    "ai",
    "server"
  ],
  "author": "SMK Dev Projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smk-dev-projects/mcp-generator.git"
  },
  "bugs": {
    "url": "https://github.com/smk-dev-projects/mcp-generator/issues"
  },
  "homepage": "https://github.com/smk-dev-projects/mcp-generator#readme",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "handlebars": "^4.7.8",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
